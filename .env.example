# Public site URL (recommended)
NEXT_PUBLIC_SITE_URL=

# OpenClaw gateway (optional)
OPENCLAW_GATEWAY_URL=

# Calendar proxy (optional)
CALENDAR_PROXY_URL=
CALENDAR_PROXY_TOKEN=
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

